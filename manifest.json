{
  "manifest_version": 3,
  "name": "Seenit! - Episode Tracker",
  "description": "Keep track of your favorite series and episodes with a simple, cozy interface. Works offline and supports dark/light themes.",
  "version": "1.0.3",
  "permissions": [
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "1074219223638-fjvp4moemeu6qe47u7go0k7sne5k6m2a.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "host_permissions": [
    "https://api.tvmaze.com/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_title": "Seenit! - Episode Tracker",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
