{
  "name": "seenit-episode-tracker",
  "version": "1.1.1",
  "description": "Keep track of your favorite series and episodes in a simple, cozy interface. Works offline with dark and light themes.",
  "license": "Source-Available, Non-Commercial License (Proprietary)",
  "repository": {
    "type": "git",
    "url": "https://github.com/farengeyt451/seenit-extension"
  },
  "scripts": {
    "build": "vite build --config vite.config.chrome.ts",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "dev": "nodemon --config nodemon.chrome.json",
    "dev:chrome": "nodemon --config nodemon.chrome.json",
    "dev:chrome:prod": "nodemon --config nodemon.chrome.json -- --mode production",
    "dev:firefox": "nodemon --config nodemon.firefox.json",
    "check-types": "tsc"
  },
  "type": "module",
  "dependencies": {
