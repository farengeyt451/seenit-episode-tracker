    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "luxon": "^3.7.2",
    "react-dom": "^19.2.6",
    "react-rewards": "^2.1.0",
    "react": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.1.42",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
